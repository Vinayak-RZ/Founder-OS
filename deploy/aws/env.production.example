# /etc/founder-os/env — production secrets (chmod 600)

# ── Public URL (required for OAuth + correct redirects) ───
PUBLIC_BASE_URL=https://YOUR_DOMAIN
BEHIND_PROXY=true

# ── Data on EBS (persistent across deploys) ─────────────
FOUNDER_OS_DATA=/var/lib/founder-os/data
FOUNDER_OS_DB=/var/lib/founder-os/data/founder_os.db
KNOWLEDGE_VAULT_ROOT=/var/lib/founder-os/data/knowledge
GITHUB_TOKEN_PATH=/var/lib/founder-os/data/github_token.json
GOOGLE_TOKEN_PATH=/var/lib/founder-os/data/google_token.json
GOOGLE_CREDENTIALS_PATH=/var/lib/founder-os/data/google_credentials.json

# ── Web (Gunicorn binds localhost; nginx terminates TLS) ─
WEB_UI_ENABLED=true
TELEGRAM_ENABLED=false
WEB_HOST=127.0.0.1
DASHBOARD_PORT=8787
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# ── LLM (at least one required) ─────────────────────────
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Qdrant Cloud ────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=founder_os

# ── S3 vault storage (use IAM role — leave keys empty) ──
AWS_S3_BUCKET=founder-os-vault-YOURNAME
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Identity ────────────────────────────────────────────
MY_NAME=
MY_COMPANY_NAME=
MY_ROLE=Founder
MY_ONE_LINER=

# ── Agent policy ────────────────────────────────────────
AUTONOMY_LEVEL=balanced
AUTO_APPROVE=false
AGENT_PAUSED=false
PUBLIC_ACCESS=false

# ── GitHub (optional) ───────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://YOUR_DOMAIN/api/github/callback

# ── Optional integrations ───────────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
SERPER_API_KEY=
TAVILY_API_KEY=
